# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
# Ignore build artifacts under dist/, but keep the Flatpak / AppImage / RPM /
# deb packaging sources tracked — only the built bundles / output dirs are ignored.
/dist/*
!/dist/flatpak/
/dist/flatpak/qeth.flatpak
!/dist/appimage/
/dist/appimage/out/
/dist/appimage/.helios/
!/dist/rpm/
/dist/rpm/*.rpm
!/dist/deb/
/dist/deb/*.deb

# venv
.venv/
venv/

# IDE
.idea/
.vscode/

# OS
.DS_Store

# Claude Code per-machine settings
.claude/settings.local.json

# mypy type-checker cache
.mypy_cache/

# Local test config (e.g. a local archive node for the anvil fork). NOT committed.
.env

# verify-variant build artifacts (deb/rpm already covered above by
# /dist/{deb,rpm}/* ; these cover the flatpak/appimage bundles + build temps)
/dist/flatpak/*.flatpak
/dist/appimage/*.AppImage
dist/flatpak/helios
dist/flatpak/.qeth-verify.yml
